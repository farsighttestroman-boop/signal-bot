# ── Signal bot ──────────────────────────────────────────────────────────────
# Phone number the bot listens on (E.164 format).
# Leave blank on first run; set it after linking via http://localhost:5001/link
SIGNAL_NUMBER=+380984816003

# How often to poll Signal for new messages (seconds)
POLL_INTERVAL_SECONDS=3

# ── FreeTakServer ────────────────────────────────────────────────────────────
# Internal Docker hostname — matches the service name in ~/UI/docker-compose.yaml
FTS_HOST=freetakserver
FTS_PORT=8087

# ── UI ───────────────────────────────────────────────────────────────────────
UI_SECRET_KEY=change-me-in-production

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
